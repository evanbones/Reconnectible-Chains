{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "homepage": "https://github.com/evanbones/ConnectibleChains",
    "sources": "https://github.com/evanbones/ConnectibleChains"
  },
  "license": "${license}",
  "icon": "${mod_id}.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.evandev.connectiblechains.ConnectibleChainsMod"
    ],
    "client": [
      "com.evandev.connectiblechains.client.ConnectibleChainsModClient"
    ],
    "modmenu": [
      "com.evandev.connectiblechains.compat.ModMenuIntegration"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json",
    "${mod_id}.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "minecraft": ">=26.1 <=26.2",
    "java": ">=${java_version}",
    "cloth-config": ">=26.1.154"
  },
  "suggests": {
    "modmenu": ">=11.0.3"
  }
}
